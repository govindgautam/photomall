# ============================================
# DATABASE CONFIGURATION
# ============================================

# Supabase (Production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_DATABASE_PASSWORD=your-database-password
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Database URL (Optional - overrides Supabase config)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?sslmode=require

# Local PostgreSQL (Development)
DB_USER=postgres
DB_PASSWORD=postgres123
DB_NAME=event_photo_db
DB_PORT=5432

# ============================================
# AUTHENTICATION
# ============================================

SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# EMAIL CONFIGURATION
# ============================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# ============================================
# URLS
# ============================================

# Frontend URL (for CORS and callbacks)
FRONTEND_URL=https://your-domain.com

# Backend API URL
BACKEND_URL=https://api.your-domain.com

# Next.js public backend URL (for client-side API calls)
NEXT_PUBLIC_BACKEND_URL=https://api.your-domain.com

# ============================================
# DEPLOYMENT MODE
# ============================================

# Cloud Mode: true = disable heavy face recognition (for Coolify deployment)
# false = enable full face recognition (for local development)
CLOUD_MODE=true

# ============================================
# FILE UPLOAD
# ============================================

MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# ============================================
# AI FACE DETECTION
# ============================================

FACE_DETECTION_BACKEND=mtcnn
FACE_MODEL_NAME=Facenet512
SIMILARITY_THRESHOLD=0.85

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# PORT CONFIGURATIONS
# ============================================

BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=80
NGINX_SSL_PORT=443

# ============================================
# COOLIFY DEPLOYMENT (Specific Settings)
# ============================================

# Set these in Coolify's environment variables section
# Do NOT commit actual values to Git